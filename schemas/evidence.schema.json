{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence",
  "title": "Media hit evidence record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "url", "outlet", "media_type", "title",
    "published_date", "discovered_date", "statements"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "url": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "outlet": { "type": "string", "minLength": 1 },
    "media_type": {
      "type": "string",
      "enum": ["article", "podcast", "youtube", "website", "social", "manual"]
    },
    "title": { "type": "string", "minLength": 1 },
    "published_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "discovered_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "transcript_ref": { "type": ["string", "null"] },
    "statements": {
      "type": "array",
      "items": { "$ref": "#/$defs/statement" }
    }
  },
  "$defs": {
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate", "topic", "stance", "summary",
        "quote", "confidence", "is_housing", "attribution_flag"
      ],
      "properties": {
        "candidate": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "topic": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "stance": {
          "type": "string",
          "enum": ["supports", "supports-with-conditions", "opposes", "mixed", "no-position"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "quote": { "type": "string", "minLength": 1 },
        "locator": { "type": ["string", "null"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "is_housing": { "type": "boolean" },
        "attribution_flag": { "type": "boolean" }
      }
    }
  }
}
