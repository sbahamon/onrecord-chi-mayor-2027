{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stance",
  "title": "Curated stance (matrix cell)",
  "type": "object",
  "additionalProperties": false,
  "required": ["candidate", "topic", "stance", "summary", "citations", "updated_date"],
  "properties": {
    "candidate": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "topic": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "stance": {
      "type": "string",
      "enum": ["supports", "supports-with-conditions", "opposes", "mixed", "no-position"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "citations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "updated_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
