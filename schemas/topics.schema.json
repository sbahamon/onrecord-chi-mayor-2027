{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "topics",
  "title": "Housing topic taxonomy (matrix rows)",
  "type": "object",
  "additionalProperties": false,
  "required": ["topics"],
  "properties": {
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "label"],
        "properties": {
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": ["string", "null"] },
          "order": { "type": "integer" }
        }
      }
    }
  }
}
