---
import Base from "../layouts/Base.astro";
import { loadDroppedCandidates } from "../lib/data.js";
const base = import.meta.env.BASE_URL;
const dropped = loadDroppedCandidates();
---
<Base title="Methodology" description="How the Chicago Housing Tracker finds, extracts, and reviews candidate positions.">
  <section class="hero"><h1>Methodology</h1></section>
  <div class="prose">
    <p>
      This tracker records where 2027 Chicago mayoral candidates stand on housing,
      based on what they say in public media — podcasts, interviews, candidate
      forums, and news coverage. It is an accountability tool: every position
      links back to the source it came from.
    </p>

    <h2>How positions get here</h2>
    <ol>
      <li><strong>Discovery.</strong> On a schedule, the system scans news feeds,
        candidate websites, and outlet pages for new appearances.</li>
      <li><strong>Ingestion.</strong> Articles are read as text; videos use their
        captions; audio is transcribed. We store only the extracted quotes and a
        link to the source — not full transcripts or media files.</li>
      <li><strong>Extraction.</strong> An AI model reads the transcript and drafts
        each housing position with the exact supporting quote.</li>
      <li><strong>Review.</strong> A second, independent AI model checks that each
        quote is real and correctly attributed. Then a <em>human</em> reviews and
        approves every position before it appears here.</li>
    </ol>

    <h2>What we do and don't claim</h2>
    <p>
      Summaries are our paraphrase; the linked quote and source are the record.
      A blank cell means a candidate has not addressed that issue on the record
      that we've found — not that they have no view. We track housing closely;
      other issues a candidate raises are noted internally but not published here.
    </p>

    {dropped.length > 0 && (
      <>
        <h2>Candidates we don't track</h2>
        <p>
          We focus on candidates with a realistic path in the race. These
          declared candidates are not shown in the matrix; we'll add anyone here
          if that changes or they put a housing position on the record.
        </p>
        <ul>
          {dropped.map((c) => (
            <li>
              <strong>{c.name}</strong>
              {c.drop_reason ? " — " + c.drop_reason : ""}
            </li>
          ))}
        </ul>
      </>
    )}

    <h2>Corrections</h2>
    <p>
      Found a misquote, a wrong attribution, or a missed appearance? Corrections
      are welcome and taken seriously. Please
      <a href="https://github.com/sbahamon/onrecord-chi-mayor-2027/issues/new/choose">open an issue</a>
      — you can also use that form to submit a media link for us to process.
    </p>
  </div>
</Base>
