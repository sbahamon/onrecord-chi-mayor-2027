# Copy to .env and fill in. .env is gitignored — never commit real keys.
# These are NOT needed for unit tests (which run on fixtures) or the site build.
# They are needed starting at the "API-KEY CHECKPOINT" step (live ingest/extract).

# OpenRouter — https://openrouter.ai/settings/keys (load ~$10 prepaid credit first)
OPENROUTER_API_KEY=

# Groq — https://console.groq.com/keys (free tier covers early testing)
GROQ_API_KEY=

# Optional: override default models (see data/registry/config.json for defaults)
# EXTRACTOR_MODEL=deepseek/deepseek-chat-v3.2
# REVIEWER_MODEL=moonshotai/kimi-k2
